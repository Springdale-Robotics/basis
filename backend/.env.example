# ============================================
# REQUIRED - Application will not start without these
# ============================================

# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/homemanager

# Redis connection string
REDIS_URL=redis://localhost:6379

# Secret for session encryption (minimum 32 characters)
SESSION_SECRET=your-super-secret-session-key-minimum-32-chars

# Secret for encrypting sensitive data at rest (32 bytes, hex-encoded)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================
# OPTIONAL - Defaults provided
# ============================================

# Environment
NODE_ENV=production
LOG_LEVEL=info

# Server
HOST=0.0.0.0
PORT=3000
WEBSOCKET_PORT=3001

# Security
CORS_ORIGINS=
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Database
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# Session
SESSION_MAX_AGE_MS=604800000

# File Storage
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=100

# ============================================
# EXTERNAL INTEGRATIONS (Optional)
# ============================================

# Google Calendar Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft/Outlook Integration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Cloudflare Tunnel (if using)
CLOUDFLARE_TUNNEL_TOKEN=

# Spotify Integration
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_AI_FEATURES=false
ENABLE_SMART_HOME=true
ENABLE_DLNA_SERVER=true
ENABLE_METRICS=true

# ============================================
# DEVELOPMENT ONLY
# ============================================

# DEBUG=*
# DISABLE_RATE_LIMIT=true
# DISABLE_CSRF=true
