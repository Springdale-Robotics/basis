{
  "name": "homemanager-backend",
  "version": "1.0.0",
  "description": "Basis — Self-hosted household management server",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Springdale-Robotics/basis.git",
    "directory": "backend"
  },
  "bugs": {
    "url": "https://github.com/Springdale-Robotics/basis/issues"
  },
  "homepage": "https://github.com/Springdale-Robotics/basis",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "setup": "tsx scripts/setup.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "homemanager",
    "household",
    "self-hosted",
    "calendar",
    "recipes",
    "inventory"
  ],
  "author": "",
  "license": "MIT",
